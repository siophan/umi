{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@joy/shared": ["packages/shared/src/index.ts"],
      "@joy/shared/*": ["packages/shared/src/*"],
      "@joy/config": ["packages/config/src/index.ts"],
      "@joy/config/*": ["packages/config/*"],
      "@joy/db": ["packages/db/src/index.ts"],
      "@joy/db/*": ["packages/db/*"]
    }
  }
}
